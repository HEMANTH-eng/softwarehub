<!-- 🔔 NOTIFICATION & ALERT BANNER CARD -->
<div id="notification-banner-widget" class="hidden bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-lg text-white">
  <div class="flex items-center justify-between border-b border-slate-800 pb-3 mb-4">
    <div class="flex items-center gap-2.5">
      <div class="p-2 bg-blue-500/20 text-blue-400 rounded-xl border border-blue-400/30">
        <i data-lucide="bell" class="w-4 h-4"></i>
      </div>
      <div>
        <h3 class="text-xs font-extrabold uppercase tracking-wider text-white">Admin Action Alerts & Requests</h3>
        <p class="text-[11px] text-slate-400">Visitor requests & maintenance update alerts requiring attention.</p>
      </div>
    </div>
    <span id="widget-alert-badge" class="text-[10px] font-bold bg-blue-500/20 text-blue-300 border border-blue-400/30 px-2.5 py-0.5 rounded-full">Active Alerts</span>
  </div>

  <div id="widget-alert-list" class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
    <!-- Loaded dynamically -->
  </div>
</div>

<script>
  (function() {
    const widget = document.getElementById('notification-banner-widget');
    const list = document.getElementById('widget-alert-list');

    async function fetchWidgetAlerts() {
      try {
        const res = await fetch('/admin/api/notifications', {
          headers: { 'Accept': 'application/json' }
        });
        if (!res.ok) return;
        const data = await res.json();

        if (data.success && data.notifications && data.notifications.length > 0) {
          widget.classList.remove('hidden');
          list.innerHTML = '';

          // Show top 4 alerts
          data.notifications.slice(0, 4).forEach(item => {
            const card = document.createElement('div');
            card.className = 'bg-slate-950 border border-slate-800 rounded-xl p-3 flex items-start justify-between gap-3';

            let actionHtml = '';
            if (item.type === 'app_request') {
              actionHtml = `<button data-app="${item.app_name}" data-reqid="${item.raw_id}" class="widget-fulfill-btn bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold px-3 py-1.5 rounded-lg text-[10px] flex items-center gap-1 shrink-0 shadow-md">
                <i data-lucide="zap" class="w-3 h-3 fill-amber-300 text-amber-300"></i> Auto Publish
              </button>`;
            } else {
              actionHtml = `<button data-app="${item.app_name}" class="widget-update-btn bg-slate-800 hover:bg-slate-700 text-indigo-300 border border-slate-700 font-bold px-3 py-1.5 rounded-lg text-[10px] flex items-center gap-1 shrink-0">
                <i data-lucide="refresh-cw" class="w-3 h-3 text-indigo-400"></i> Check
              </button>`;
            }

            card.innerHTML = `
              <div class="min-w-0 flex-grow">
                <span class="text-[9px] font-bold border px-2 py-0.5 rounded-full uppercase ${item.badge_color}">${item.badge}</span>
                <h4 class="font-bold text-white text-xs mt-1.5 truncate">${item.title}</h4>
                <p class="text-slate-400 text-[11px] mt-0.5 truncate">${item.message}</p>
              </div>
              <div class="flex flex-col items-end gap-2">
                ${actionHtml}
              </div>
            `;

            list.appendChild(card);
          });

          if (window.lucide) lucide.createIcons();

          // Bind click handlers
          list.querySelectorAll('.widget-fulfill-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
              const appName = btn.dataset.app;
              const reqId = btn.dataset.reqid;
              btn.disabled = true;
              btn.textContent = 'Publishing...';
              try {
                const res = await fetch('/admin/api/notifications/fulfill-request', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ request_id: reqId, app_name: appName })
                });
                const result = await res.json();
                if (result.success) {
                  alert(`🎉 Published "${appName}" successfully!`);
                  window.location.reload();
                } else {
                  alert('Error: ' + result.error);
                }
              } catch (e) {
                alert('Error: ' + e.message);
              } finally {
                btn.disabled = false;
              }
            });
          });

          list.querySelectorAll('.widget-update-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              const appName = btn.dataset.app;
              const input = document.getElementById('auto-pub-name-input');
              if (input) {
                input.value = appName;
                document.getElementById('auto-pub-search-btn')?.click();
              }
            });
          });

        } else {
          widget.classList.add('hidden');
        }
      } catch (e) {
        console.warn('[NotificationWidget] Fetch error:', e);
      }
    }

    fetchWidgetAlerts();
  })();
</script>
