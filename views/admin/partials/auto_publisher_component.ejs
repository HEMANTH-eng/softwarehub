<!-- ⚡ ONE-CLICK AUTO PUBLISHER COMPONENT -->
<div class="bg-gradient-to-r from-slate-950 via-blue-950 to-indigo-950 rounded-2xl p-6 shadow-xl border border-blue-800/40 text-white relative overflow-hidden">
  <!-- Decorative Glow -->
  <div class="absolute -right-12 -bottom-12 w-56 h-56 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -left-12 -top-12 w-56 h-56 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between border-b border-blue-800/30 pb-4 mb-5 gap-3">
    <div class="flex items-center gap-3">
      <div class="bg-gradient-to-tr from-blue-600 to-indigo-500 p-2.5 rounded-xl text-white shadow-lg shadow-blue-500/30">
        <i data-lucide="zap" class="w-5 h-5 text-amber-300 fill-amber-300"></i>
      </div>
      <div>
        <h2 class="text-base font-extrabold tracking-wide flex items-center gap-2">
          <span>One-Click Auto Publisher</span>
          <span class="text-[10px] font-bold uppercase tracking-wider bg-amber-400/20 text-amber-300 border border-amber-400/30 px-2.5 py-0.5 rounded-full">AI Web Search & Publish</span>
        </h2>
        <p class="text-xs text-blue-200/80 mt-0.5">Type any software name (e.g., Google Chrome, VLC Media Player). AI searches the web, gathers version, logo, screenshots, details, & publishes live in 1-click.</p>
      </div>
    </div>
  </div>

  <form id="auto-publish-search-form" class="space-y-4">
    <div class="flex flex-col sm:flex-row gap-3">
      <div class="relative flex-grow">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-blue-300">
          <i data-lucide="search" class="w-4 h-4"></i>
        </div>
        <input 
          type="text" 
          id="auto-pub-name-input" 
          placeholder="Enter Software Name (e.g. Google Chrome, 7-Zip, Notepad++, VLC)" 
          required 
          class="w-full bg-slate-900/90 border border-blue-700/50 rounded-xl pl-10 pr-4 py-3 text-xs sm:text-sm text-white placeholder-slate-400 focus:outline-none focus:border-amber-400 focus:ring-1 focus:ring-amber-400 shadow-inner"
        >
      </div>

      <button 
        type="submit" 
        id="auto-pub-search-btn" 
        class="bg-gradient-to-r from-amber-500 via-amber-600 to-amber-500 hover:from-amber-400 hover:to-amber-500 text-slate-950 font-black text-xs sm:text-sm px-6 py-3 rounded-xl shadow-lg shadow-amber-500/20 transition-all flex items-center justify-center gap-2 shrink-0 focus:outline-none"
      >
        <i data-lucide="zap" class="w-4 h-4 fill-slate-950"></i>
        <span>⚡ Discover & Preview</span>
      </button>
    </div>

    <!-- Status Loading State -->
    <div id="auto-pub-status-box" class="hidden flex items-center gap-3 p-3 rounded-xl bg-blue-900/40 border border-blue-700/50 text-xs text-blue-200">
      <div class="w-4 h-4 border-2 border-amber-400 border-t-transparent rounded-full animate-spin"></div>
      <span id="auto-pub-status-msg" class="font-medium">Searching web for official landing page & download links...</span>
    </div>

    <!-- Alert Box -->
    <div id="auto-pub-alert" class="hidden p-3 rounded-xl text-xs font-medium border"></div>
  </form>
</div>

<!-- 🚀 LIVE INTERACTIVE PREVIEW MODAL -->
<div id="auto-preview-modal" class="fixed inset-0 z-50 overflow-y-auto hidden">
  <div class="fixed inset-0 bg-slate-950/70 backdrop-blur-md" id="auto-preview-backdrop"></div>
  
  <div class="flex min-h-full items-center justify-center p-4 text-center">
    <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all w-full max-w-3xl border border-slate-100 p-6 sm:p-8">
      
      <!-- Close Button -->
      <button id="close-auto-preview-btn" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 p-1 rounded-full hover:bg-slate-100">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>

      <!-- Modal Title -->
      <div class="flex items-center gap-2 border-b border-slate-100 pb-3 mb-6">
        <span class="p-1.5 rounded-lg bg-amber-50 text-amber-600">
          <i data-lucide="eye" class="w-5 h-5"></i>
        </span>
        <div>
          <h3 class="text-base font-bold text-slate-900 uppercase tracking-wider">Software Live Preview</h3>
          <p class="text-xs text-slate-400">Review collected metadata and media before publishing to website.</p>
        </div>
      </div>

      <!-- Preview Header Card -->
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-white rounded-xl border border-slate-200 p-1 flex items-center justify-center shrink-0 shadow-sm">
          <img id="prev-logo" src="" alt="Software Logo" class="w-full h-full object-cover rounded-lg">
        </div>
        <div class="flex-grow min-w-0">
          <div class="flex flex-wrap gap-2 items-center mb-1">
            <span id="prev-category-badge" class="px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-200 uppercase">Category</span>
            <span id="prev-version-badge" class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-slate-200 text-slate-700">v1.0.0</span>
            <span id="prev-size-badge" class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">25.0 MB</span>
          </div>
          <h2 id="prev-name" class="text-xl font-extrabold text-slate-900 truncate">Software Name</h2>
          <span id="prev-short-desc" class="text-xs text-slate-500 block truncate mt-0.5">Short description snippet</span>
        </div>
      </div>

      <!-- Preview Body Tabs/Details -->
      <div class="space-y-4 text-xs text-slate-600 max-h-[50vh] overflow-y-auto pr-2">
        
        <!-- Grid Specs -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 bg-slate-50/60 p-3 rounded-xl border border-slate-100">
          <div>
            <span class="text-[10px] font-bold text-slate-400 block uppercase">Developer</span>
            <span id="prev-developer" class="font-semibold text-slate-700 block truncate">Google LLC</span>
          </div>
          <div>
            <span class="text-[10px] font-bold text-slate-400 block uppercase">License</span>
            <span id="prev-license" class="font-semibold text-slate-700 block truncate">Freeware</span>
          </div>
          <div>
            <span class="text-[10px] font-bold text-slate-400 block uppercase">Architecture</span>
            <span id="prev-arch" class="font-semibold text-slate-700 block truncate">64-bit (x64)</span>
          </div>
          <div>
            <span class="text-[10px] font-bold text-slate-400 block uppercase">Supported OS</span>
            <span id="prev-os" class="font-semibold text-slate-700 block truncate">Windows 11, 10</span>
          </div>
        </div>

        <!-- Full Description -->
        <div>
          <h4 class="font-bold text-slate-800 uppercase tracking-wider text-[11px] mb-1">Full Overview</h4>
          <p id="prev-full-desc" class="bg-white border border-slate-200 p-3 rounded-xl leading-relaxed text-slate-700 whitespace-pre-line">Description</p>
        </div>

        <!-- Features & System Requirements -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <h4 class="font-bold text-slate-800 uppercase tracking-wider text-[11px] mb-1">Key Features</h4>
            <div id="prev-features" class="bg-white border border-slate-200 p-3 rounded-xl space-y-1"></div>
          </div>
          <div>
            <h4 class="font-bold text-slate-800 uppercase tracking-wider text-[11px] mb-1">System Requirements</h4>
            <p id="prev-sysreq" class="bg-white border border-slate-200 p-3 rounded-xl leading-relaxed text-slate-700 whitespace-pre-line">Requirements</p>
          </div>
        </div>

        <!-- SEO Metadata -->
        <div class="bg-slate-50 p-3 rounded-xl border border-slate-200 space-y-1">
          <span class="text-[10px] font-bold text-slate-400 block uppercase">SEO Title & Meta Keywords</span>
          <span id="prev-seo-title" class="font-bold text-blue-700 block">Download Software</span>
          <span id="prev-seo-keywords" class="text-[10px] text-slate-500 block truncate">keywords</span>
        </div>

      </div>

      <!-- Action Footer -->
      <div class="flex items-center justify-between gap-3 border-t border-slate-100 pt-4 mt-6">
        <button 
          type="button" 
          id="customize-auto-pub-btn" 
          class="px-4 py-2 border border-slate-200 rounded-xl text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-colors flex items-center gap-1.5 focus:outline-none"
        >
          <i data-lucide="edit-3" class="w-4 h-4"></i>
          <span>✏️ Edit & Customize</span>
        </button>

        <button 
          type="button" 
          id="confirm-auto-publish-btn" 
          class="px-6 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 text-white font-bold text-xs rounded-xl shadow-md transition-all flex items-center gap-2 focus:outline-none"
        >
          <i data-lucide="rocket" class="w-4 h-4"></i>
          <span>🚀 Publish Now</span>
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    let currentAutoPreviewPayload = null;

    const form = document.getElementById('auto-publish-search-form');
    const input = document.getElementById('auto-pub-name-input');
    const searchBtn = document.getElementById('auto-pub-search-btn');
    const statusBox = document.getElementById('auto-pub-status-box');
    const statusMsg = document.getElementById('auto-pub-status-msg');
    const alertBox = document.getElementById('auto-pub-alert');

    // Preview Modal Elements
    const previewModal = document.getElementById('auto-preview-modal');
    const closePreviewBtn = document.getElementById('close-auto-preview-btn');
    const previewBackdrop = document.getElementById('auto-preview-backdrop');
    const customizeBtn = document.getElementById('customize-auto-pub-btn');
    const publishBtn = document.getElementById('confirm-auto-publish-btn');

    // Field Bindings
    const prevLogo = document.getElementById('prev-logo');
    const prevName = document.getElementById('prev-name');
    const prevCat = document.getElementById('prev-category-badge');
    const prevVer = document.getElementById('prev-version-badge');
    const prevSize = document.getElementById('prev-size-badge');
    const prevShortDesc = document.getElementById('prev-short-desc');
    const prevFullDesc = document.getElementById('prev-full-desc');
    const prevDev = document.getElementById('prev-developer');
    const prevLicense = document.getElementById('prev-license');
    const prevArch = document.getElementById('prev-arch');
    const prevOs = document.getElementById('prev-os');
    const prevFeatures = document.getElementById('prev-features');
    const prevSysreq = document.getElementById('prev-sysreq');
    const prevSeoTitle = document.getElementById('prev-seo-title');
    const prevSeoKeywords = document.getElementById('prev-seo-keywords');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const softwareName = input.value.trim();
        if (!softwareName) return;

        // UI Loading state
        statusBox.classList.remove('hidden');
        alertBox.classList.add('hidden');
        searchBtn.disabled = true;
        searchBtn.classList.add('opacity-50', 'cursor-not-allowed');

        const steps = [
          'Searching web for official landing page & download links...',
          'Fetching official logo & high-res screenshots...',
          'Synthesizing features, system requirements & changelog...',
          'Formatting SEO titles, metadata & FAQs...'
        ];
        let stepIdx = 0;
        const interval = setInterval(() => {
          stepIdx = (stepIdx + 1) % steps.length;
          statusMsg.textContent = steps[stepIdx];
        }, 2200);

        try {
          const res = await fetch('/admin/ai/auto-search', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ software_name: softwareName })
          });

          clearInterval(interval);

          const contentType = res.headers.get('content-type') || '';
          if (!contentType.includes('application/json')) {
            throw new Error('Your admin session may have expired or server returned non-JSON. Please refresh the page or log in again.');
          }

          const data = await res.json();
          if (!res.ok || !data.success) {
            throw new Error(data.error || 'Software discovery failed.');
          }

          currentAutoPreviewPayload = data.preview;
          renderPreviewModal(data.preview);

        } catch (err) {
          clearInterval(interval);
          alertBox.classList.remove('hidden', 'bg-emerald-900/40', 'border-emerald-700/50', 'text-emerald-200');
          alertBox.classList.add('bg-red-900/40', 'border-red-700/50', 'text-red-200');
          alertBox.textContent = err.message || 'Error conducting auto search.';
        } finally {
          statusBox.classList.add('hidden');
          searchBtn.disabled = false;
          searchBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      });
    }

    function renderPreviewModal(p) {
      prevName.textContent = p.name || 'Software';
      prevVer.textContent = 'v' + (p.version || '1.0.0');
      prevSize.textContent = p.size || '25.0 MB';
      prevShortDesc.textContent = p.short_description || '';
      prevFullDesc.textContent = p.full_description || '';

      prevDev.textContent = p.developer || 'Official Developer';
      prevLicense.textContent = p.license || 'Freeware';
      prevArch.textContent = p.architecture || '64-bit (x64)';
      prevOs.textContent = p.operating_systems || 'Windows 11, 10';

      prevSysreq.textContent = p.system_requirements || 'Standard System Requirements';
      prevSeoTitle.textContent = p.seo_title || `Download ${p.name}`;
      prevSeoKeywords.textContent = p.seo_keywords || `${p.name}, download`;

      if (p.icon_image) {
        prevLogo.src = '/storage/images/' + p.icon_image;
      } else {
        prevLogo.src = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="%233b82f6" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>';
      }

      // Render Features list
      prevFeatures.innerHTML = '';
      if (Array.isArray(p.features) && p.features.length > 0) {
        p.features.forEach(f => {
          const item = document.createElement('div');
          item.className = 'flex items-center gap-1.5 text-slate-700';
          item.innerHTML = `<i data-lucide="check-circle-2" class="w-3.5 h-3.5 text-emerald-500 shrink-0"></i><span>${f}</span>`;
          prevFeatures.appendChild(item);
        });
      } else {
        prevFeatures.innerHTML = '<span class="text-slate-400">Standard Features</span>';
      }

      previewModal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
      if (window.lucide) lucide.createIcons();
    }

    const closePreview = () => {
      previewModal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    };

    if (closePreviewBtn) closePreviewBtn.addEventListener('click', closePreview);
    if (previewBackdrop) previewBackdrop.addEventListener('click', closePreview);

    // Customize Button Click (Transfers preview data to full manual editor modal)
    if (customizeBtn) {
      customizeBtn.addEventListener('click', () => {
        closePreview();
        if (currentAutoPreviewPayload && typeof window.populateFullEditorFromAutoPayload === 'function') {
          window.populateFullEditorFromAutoPayload(currentAutoPreviewPayload);
        }
      });
    }

    // Publish Now Click
    if (publishBtn) {
      publishBtn.addEventListener('click', async () => {
        if (!currentAutoPreviewPayload) return;

        publishBtn.disabled = true;
        publishBtn.textContent = '🚀 Publishing to Site...';

        try {
          const res = await fetch('/admin/ai/auto-publish', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify(currentAutoPreviewPayload)
          });

          const contentType = res.headers.get('content-type') || '';
          if (!contentType.includes('application/json')) {
            throw new Error('Your admin session may have expired or server returned non-JSON. Please refresh the page or log in again.');
          }

          const result = await res.json();
          if (!res.ok || !result.success) {
            throw new Error(result.error || 'Publish failed.');
          }

          closePreview();
          alert('🎉 "' + currentAutoPreviewPayload.name + '" has been published to your website live!');
          window.location.reload();

        } catch (err) {
          alert('Publish Error: ' + err.message);
        } finally {
          publishBtn.disabled = false;
          publishBtn.textContent = '🚀 Publish Now';
        }
      });
    }

  })();
</script>
