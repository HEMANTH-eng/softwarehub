<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= siteTitle %></title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col">

  <!-- Top Admin Nav Banner -->
  <header class="bg-slate-900 text-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center space-x-3">
          <div class="bg-blue-600 p-2 rounded-lg text-white">
            <i data-lucide="shield-check" class="w-5 h-5"></i>
          </div>
          <span class="font-extrabold text-base tracking-tight"><%= config.site.name %> Admin Panel</span>
        </div>

        <div class="flex items-center space-x-4 text-sm font-medium">
          <span class="text-slate-400">Welcome, <strong><%= adminUsername %></strong></span>
          <div class="h-4 w-[1px] bg-slate-700"></div>
          <a href="/" target="_blank" class="text-slate-300 hover:text-white flex items-center gap-1.5 transition-colors">
            <span>View Site</span>
            <i data-lucide="external-link" class="w-3.5 h-3.5"></i>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Navigation Tab Bar -->
  <div class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex space-x-8">
        <a href="/admin/dashboard" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/software" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="package" class="w-4 h-4"></i>
          <span>Manage Software</span>
        </a>
        <a href="/admin/categories" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="tag" class="w-4 h-4"></i>
          <span>Categories</span>
        </a>
        <a href="/admin/requests" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-blue-600 text-blue-600">
          <i data-lucide="message-square" class="w-4 h-4"></i>
          <span>App Requests</span>
        </a>
        <a href="/admin/settings" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="settings" class="w-4 h-4"></i>
          <span>Ad & Site Settings</span>
        </a>
        <a href="/admin/logout" class="py-4 px-1 border-b-2 border-transparent font-bold text-sm text-red-500 hover:text-red-700 flex items-center gap-2 ml-auto">
          <i data-lucide="log-out" class="w-4 h-4"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Body Content Grid -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow space-y-6">
    
    <div class="flex items-center justify-between border-b border-slate-200 pb-4">
      <div>
        <h1 class="text-xl font-bold text-slate-900">User App Requests</h1>
        <p class="text-xs text-slate-400 mt-0.5">Manage and review software requests submitted by site visitors.</p>
      </div>
    </div>

    <!-- Requests Table -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs border-collapse">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-400 font-bold uppercase tracking-wider">
              <th class="p-4">Requested Software</th>
              <th class="p-4">User Contact</th>
              <th class="p-4">Additional Specifications</th>
              <th class="p-4">Status</th>
              <th class="p-4">Date Submitted</th>
              <th class="p-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (requestsList && requestsList.length > 0) { %>
              <% requestsList.forEach(function(req) { %>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="p-4 font-bold text-slate-800 text-sm">
                    <%= req.app_name %>
                  </td>
                  <td class="p-4 text-slate-600">
                    <% if (req.email) { %>
                      <a href="mailto:<%= req.email %>" class="text-blue-600 hover:underline flex items-center gap-1">
                        <i data-lucide="mail" class="w-3.5 h-3.5 shrink-0"></i>
                        <span><%= req.email %></span>
                      </a>
                    <% } else { %>
                      <span class="text-slate-400 italic">None Provided</span>
                    <% } %>
                  </td>
                  <td class="p-4 max-w-xs text-slate-500 whitespace-normal break-words">
                    <% if (req.details) { %>
                      <span class="block line-clamp-2" title="<%= req.details %>"><%= req.details %></span>
                    <% } else { %>
                      <span class="text-slate-400 italic font-light">-</span>
                    <% } %>
                  </td>
                  <td class="p-4">
                    <% if (req.status === 'fulfilled') { %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200 uppercase">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        <span>Fulfilled</span>
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-200 uppercase">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                        <span>Pending</span>
                      </span>
                    <% } %>
                  </td>
                  <td class="p-4 text-slate-400">
                    <%= new Date(req.created_at).toLocaleString() %>
                  </td>
                  <td class="p-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      
                      <!-- Status Toggle Button -->
                      <form action="/admin/requests/status/<%= req.id %>" method="POST">
                        <input type="hidden" name="status" value="<%= req.status === 'pending' ? 'fulfilled' : 'pending' %>">
                        <button 
                          type="submit" 
                          class="px-2.5 py-1 rounded text-[10px] font-bold transition-all border <%= req.status === 'pending' ? 'bg-emerald-50 border-emerald-200 hover:bg-emerald-100 text-emerald-700' : 'bg-amber-50 border-amber-200 hover:bg-amber-100 text-amber-700' %>"
                          title="Mark request as <%= req.status === 'pending' ? 'Fulfilled' : 'Pending' %>"
                        >
                          <% if (req.status === 'pending') { %>
                            <span>Mark Fulfilled</span>
                          <% } else { %>
                            <span>Mark Pending</span>
                          <% } %>
                        </button>
                      </form>

                      <!-- Delete Request Action -->
                      <form action="/admin/requests/delete/<%= req.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this app request?');">
                        <button 
                          type="submit" 
                          class="p-1 text-red-500 hover:bg-red-50 rounded transition-colors border border-transparent hover:border-red-100"
                          title="Delete Request"
                        >
                          <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                      </form>

                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" class="p-12 text-center text-slate-400">
                  <i data-lucide="message-square" class="w-10 h-10 text-slate-200 mx-auto mb-3"></i>
                  <p class="font-bold text-sm">No app requests submitted yet.</p>
                  <p class="text-[10px] mt-0.5">When users submit requests, they will show up here.</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

  <footer class="bg-white border-t border-slate-200 py-6 mt-12 shrink-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-xs text-slate-400">
      &copy; <%= new Date().getFullYear() %> <%= config.site.name %> Admin Console. All rights reserved.
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
