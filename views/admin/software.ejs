<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= siteTitle %></title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col">

  <!-- Admin Top Navigation -->
  <header class="bg-slate-900 text-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center space-x-3">
          <div class="bg-blue-600 p-2 rounded-lg text-white">
            <i data-lucide="shield-check" class="w-5 h-5"></i>
          </div>
          <span class="font-extrabold text-base tracking-tight"><%= config.site.name %> Admin Panel</span>
        </div>

        <div class="flex items-center space-x-4 text-sm font-medium">
          <span class="text-slate-400">Welcome, <strong><%= adminUsername %></strong></span>
          <div class="h-4 w-[1px] bg-slate-700"></div>
          <a href="/" target="_blank" class="text-slate-300 hover:text-white flex items-center gap-1.5 transition-colors">
            <span>View Site</span>
            <i data-lucide="external-link" class="w-3.5 h-3.5"></i>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Navigation Tab Bar -->
  <div class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex space-x-8">
        <a href="/admin/dashboard" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/software" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-blue-600 text-blue-600">
          <i data-lucide="package" class="w-4 h-4"></i>
          <span>Manage Software</span>
        </a>
        <a href="/admin/categories" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="tag" class="w-4 h-4"></i>
          <span>Categories</span>
        </a>
        <a href="/admin/requests" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="message-square" class="w-4 h-4"></i>
          <span>App Requests</span>
        </a>
        <a href="/admin/settings" class="py-4 px-1 border-b-2 font-bold text-sm flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">
          <i data-lucide="settings" class="w-4 h-4"></i>
          <span>Ad & Site Settings</span>
        </a>
        <a href="/admin/logout" class="py-4 px-1 border-b-2 border-transparent font-bold text-sm text-red-500 hover:text-red-700 flex items-center gap-2 ml-auto">
          <i data-lucide="log-out" class="w-4 h-4"></i>
          <span>Sign Out</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Body Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow space-y-6">

    <!-- Action Header -->
    <div class="flex items-center justify-between border-b border-slate-200 pb-4">
      <div>
        <h1 class="text-xl font-bold text-slate-900">Software Directory Listings</h1>
        <p class="text-xs text-slate-400 mt-0.5">Upload files and manage metadata for downloadable files.</p>
      </div>
      <button 
        id="add-software-btn"
        class="bg-blue-600 hover:bg-blue-700 text-white font-semibold text-xs px-4 py-2 rounded-lg shadow transition-all flex items-center gap-1.5 focus:outline-none"
      >
        <i data-lucide="plus" class="w-4 h-4"></i>
        <span>Add Software</span>
      </button>
    </div>

    <!-- Software Table -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs border-collapse">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-400 font-bold uppercase tracking-wider">
              <th class="p-4">Info</th>
              <th class="p-4">Category</th>
              <th class="p-4">Size / Version</th>
              <th class="p-4">Stats</th>
              <th class="p-4">Status</th>
              <th class="p-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (softwareList && softwareList.length > 0) { %>
              <% softwareList.forEach(function(sw) { %>
                <tr class="hover:bg-slate-50/80 transition-colors">
                  
                  <!-- Info (Icon + Name) -->
                  <td class="p-4">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 shrink-0 bg-slate-50 rounded-lg overflow-hidden border border-slate-100 flex items-center justify-center">
                        <% if (sw.icon_image) { %>
                          <img src="/storage/images/<%= sw.icon_image %>" alt="" class="w-full h-full object-cover">
                        <% } else { %>
                          <i data-lucide="package" class="w-5 h-5 text-slate-400"></i>
                        <% } %>
                      </div>
                      <div class="min-w-0">
                        <span class="font-bold text-slate-800 text-sm truncate block"><%= sw.name %></span>
                        <span class="text-[10px] text-slate-400 mt-0.5 truncate block max-w-xs"><%= sw.short_description %></span>
                      </div>
                    </div>
                  </td>

                  <!-- Category -->
                  <td class="p-4">
                    <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold bg-slate-100 border border-slate-200 text-slate-600">
                      <%= sw.category_name %>
                    </span>
                  </td>

                  <!-- Size / Version -->
                  <td class="p-4 font-medium text-slate-700">
                    <div><%= sw.size %></div>
                    <div class="text-[10px] text-slate-400 mt-0.5">v<%= sw.version || '0.0' %></div>
                  </td>

                  <!-- Stats (Views & Downloads) -->
                  <td class="p-4 text-slate-500 font-medium whitespace-nowrap">
                    <div class="flex items-center gap-1.5">
                      <i data-lucide="eye" class="w-3.5 h-3.5 text-slate-400"></i>
                      <span><%= sw.view_count %> views</span>
                    </div>
                    <div class="flex items-center gap-1.5 mt-1">
                      <i data-lucide="download" class="w-3.5 h-3.5 text-slate-400"></i>
                      <span><%= sw.download_count %> downloads</span>
                    </div>
                  </td>

                  <!-- Status (Featured & New) -->
                  <td class="p-4 space-y-1">
                    <% if (sw.is_featured) { %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-amber-50 text-[9px] font-bold text-amber-700 uppercase border border-amber-200">
                        <i data-lucide="star" class="w-2.5 h-2.5 fill-amber-400 text-amber-500"></i>
                        <span>Featured</span>
                      </span>
                    <% } %>
                    <% if (sw.is_new) { %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-emerald-50 text-[9px] font-bold text-emerald-700 uppercase border border-emerald-200 block w-max">
                        <span>New</span>
                      </span>
                    <% } %>
                    <% if (!sw.is_featured && !sw.is_new) { %>
                      <span class="text-slate-400 text-[10px] italic">Standard</span>
                    <% } %>
                  </td>

                  <!-- Actions (Edit & Delete) -->
                  <td class="p-4 text-right whitespace-nowrap">
                    <div class="inline-flex gap-2">
                      <!-- Edit Button -->
                      <button 
                        class="edit-btn p-1.5 bg-slate-100 hover:bg-slate-200 rounded-lg text-slate-600 hover:text-slate-800 transition-colors"
                        data-id="<%= sw.id %>"
                        data-name="<%= sw.name %>"
                        data-category="<%= sw.category_id %>"
                        data-short-desc="<%= sw.short_description %>"
                        data-full-desc="<%= sw.full_description %>"
                        data-version="<%= sw.version %>"
                        data-size="<%= sw.size %>"
                        data-featured="<%= sw.is_featured %>"
                        data-new="<%= sw.is_new %>"
                      >
                        <i data-lucide="edit-3" class="w-4 h-4"></i>
                      </button>

                      <!-- Delete Action form -->
                      <form action="/admin/software/delete/<%= sw.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this listing? This will permanently delete both database entries and local binary files.');">
                        <button type="submit" class="p-1.5 bg-red-50 hover:bg-red-100 rounded-lg text-red-500 hover:text-red-700 transition-colors">
                          <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                      </form>
                    </div>
                  </td>

                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" class="p-8 text-center text-slate-400">
                  <i data-lucide="package-open" class="w-10 h-10 text-slate-300 mx-auto mb-2"></i>
                  <p class="font-semibold">No software listings added yet.</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

  <!-- Software Form Modal Overlay (Initially Hidden) -->
  <div id="software-modal" class="fixed inset-0 z-50 overflow-y-auto hidden">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm" id="modal-backdrop"></div>
    
    <!-- Modal container -->
    <div class="flex min-h-full items-center justify-center p-4 text-center">
      <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all w-full max-w-2xl border border-slate-100 p-6 sm:p-8">
        
        <!-- Modal Close Button -->
        <button id="close-modal-btn" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 p-1 rounded-full hover:bg-slate-100">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>

        <!-- Form Title -->
        <h3 class="text-base font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-3 mb-6" id="modal-title">
          Add New Software Listing
        </h3>

        <!-- Form Body -->
        <form id="software-form" action="/admin/software/add" method="POST" enctype="multipart/form-data" class="space-y-5">
          
          <!-- Name & Category -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="sw-name" class="text-xs font-bold text-slate-500">Software Name *</label>
              <input 
                type="text" 
                name="name" 
                id="sw-name" 
                required 
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
              >
            </div>
            
            <div class="space-y-1">
              <label for="sw-category" class="text-xs font-bold text-slate-500">Category *</label>
              <select 
                name="category_id" 
                id="sw-category" 
                required 
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
              >
                <option value="">Select Category</option>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <!-- Version & Size -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="sw-version" class="text-xs font-bold text-slate-500">Version (e.g., 3.0.2)</label>
              <input 
                type="text" 
                name="version" 
                id="sw-version" 
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
              >
            </div>
            
            <div class="space-y-1">
              <label for="sw-size" class="text-xs font-bold text-slate-500">File Size (e.g., 45 MB) *</label>
              <input 
                type="text" 
                name="size" 
                id="sw-size" 
                required
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
              >
            </div>
          </div>

          <!-- Short Description -->
          <div class="space-y-1">
            <label for="sw-short-desc" class="text-xs font-bold text-slate-500">Short Description (Max 150 chars) *</label>
            <input 
              type="text" 
              name="short_description" 
              id="sw-short-desc" 
              required
              maxlength="150"
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
            >
          </div>

          <!-- Full Description -->
          <div class="space-y-1">
            <label for="sw-full-desc" class="text-xs font-bold text-slate-500">Full Description</label>
            <textarea 
              name="full_description" 
              id="sw-full-desc" 
              rows="4" 
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
            ></textarea>
          </div>

          <!-- File Uploads -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="sw-icon" class="text-xs font-bold text-slate-500 block">Thumbnail Icon (Image file)</label>
              <input 
                type="file" 
                name="icon_image" 
                id="sw-icon" 
                accept="image/*"
                class="w-full text-xs text-slate-500 border border-slate-200 rounded-lg px-3 py-1.5"
              >
            </div>
            
            <div class="space-y-1">
              <label for="sw-file" class="text-xs font-bold text-slate-500 block">Installer Package file *</label>
              <input 
                type="file" 
                name="software_file" 
                id="sw-file" 
                class="w-full text-xs text-slate-500 border border-slate-200 rounded-lg px-3 py-1.5"
              >
              <span id="file-helper-text" class="text-[9px] text-slate-400 block mt-0.5">Select a file from your device. Required when creating new.</span>
            </div>
          </div>

          <!-- Listing Badges Toggle -->
          <div class="flex items-center gap-6 py-2 border-t border-b border-slate-100">
            <label class="inline-flex items-center text-xs font-bold text-slate-600 gap-2 cursor-pointer">
              <input type="checkbox" name="is_featured" id="sw-featured" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500">
              <span>Mark as Featured (Carousels list)</span>
            </label>
            
            <label class="inline-flex items-center text-xs font-bold text-slate-600 gap-2 cursor-pointer">
              <input type="checkbox" name="is_new" id="sw-new" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500">
              <span>Mark as New Listing</span>
            </label>
          </div>

          <!-- Form submit/actions buttons -->
          <div class="flex justify-end gap-3 pt-3">
            <button 
              type="button" 
              id="cancel-modal-btn" 
              class="px-4 py-2 border border-slate-200 rounded-lg text-xs font-semibold hover:bg-slate-50 text-slate-500 transition-colors focus:outline-none"
            >
              Cancel
            </button>
            <button 
              type="submit" 
              class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-semibold shadow transition-all focus:outline-none"
            >
              Save Listing
            </button>
          </div>

        </form>

      </div>
    </div>
  </div>

  <!-- Admin Panel Footer -->
  <footer class="bg-white border-t border-slate-200 py-6 text-center text-xs text-slate-400 mt-12 shrink-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span><%= config.site.name %> Admin Panel Panel Dashboard</span>
    </div>
  </footer>

  <script src="/js/main.js"></script>

  <!-- Interactive Modal Script JS -->
  <script>
    const modal = document.getElementById('software-modal');
    const modalTitle = document.getElementById('modal-title');
    const softwareForm = document.getElementById('software-form');
    const swFile = document.getElementById('sw-file');
    const fileHelperText = document.getElementById('file-helper-text');
    
    // Form Inputs
    const swName = document.getElementById('sw-name');
    const swCategory = document.getElementById('sw-category');
    const swVersion = document.getElementById('sw-version');
    const swSize = document.getElementById('sw-size');
    const swShortDesc = document.getElementById('sw-short-desc');
    const swFullDesc = document.getElementById('sw-full-desc');
    const swFeatured = document.getElementById('sw-featured');
    const swNew = document.getElementById('sw-new');

    // Show Modal
    const showModal = (isEdit = false, editId = null) => {
      modal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
      
      if (isEdit) {
        modalTitle.textContent = 'Edit Software Listing';
        softwareForm.action = '/admin/software/edit/' + editId;
        // Make installer file optional for updates
        swFile.removeAttribute('required');
        fileHelperText.textContent = 'Leave empty to keep current installer package.';
      } else {
        modalTitle.textContent = 'Add New Software Listing';
        softwareForm.action = '/admin/software/add';
        // Make installer file required for creation
        swFile.setAttribute('required', 'required');
        fileHelperText.textContent = 'Select the installer file. Required.';
        
        // Reset all inputs
        softwareForm.reset();
      }
    };

    // Close Modal
    const closeModal = () => {
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
      softwareForm.reset();
    };

    // Listeners
    document.getElementById('add-software-btn').addEventListener('click', () => showModal(false));
    document.getElementById('close-modal-btn').addEventListener('click', closeModal);
    document.getElementById('cancel-modal-btn').addEventListener('click', closeModal);
    document.getElementById('modal-backdrop').addEventListener('click', closeModal);

    // Edit Buttons click binding
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        
        // Set values
        swName.value = btn.dataset.name;
        swCategory.value = btn.dataset.category;
        swVersion.value = btn.dataset.version;
        swSize.value = btn.dataset.size;
        swShortDesc.value = btn.dataset.shortDesc;
        swFullDesc.value = btn.dataset.fullDesc;
        swFeatured.checked = btn.dataset.featured === '1';
        swNew.checked = btn.dataset.new === '1';
        
        showModal(true, id);
      });
    });
  </script>
</body>
</html>
