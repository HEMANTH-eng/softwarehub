<%- include('partials/header') %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="bg-white border border-slate-200 rounded-2xl shadow-xl overflow-hidden">
    
    <!-- Header Banner -->
    <div class="bg-gradient-to-r from-slate-900 via-slate-800 to-brand-950 text-white p-8">
      <div class="flex items-center gap-3">
        <div class="bg-brand-500/20 text-brand-400 p-2.5 rounded-xl border border-brand-500/20">
          <i data-lucide="message-square-plus" class="w-6 h-6"></i>
        </div>
        <div>
          <h1 class="text-2xl font-extrabold tracking-tight">Request for Apps</h1>
          <p class="text-slate-300 text-xs mt-1">Can't find the software you are looking for? Send us a request and we'll add it to our repository.</p>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="p-8">
      <% if (typeof success !== 'undefined' && success) { %>
        <!-- Success Alert State -->
        <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-6 text-center animate-fade-in">
          <div class="bg-emerald-100 text-emerald-600 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4">
            <i data-lucide="check-circle" class="w-6 h-6"></i>
          </div>
          <h2 class="text-lg font-bold text-emerald-900">Request Submitted Successfully!</h2>
          <p class="text-emerald-700 text-xs mt-1 max-w-md mx-auto">
            We have received your app request. Our team will review it, verify the software is clean and safe, and list it as soon as possible.
          </p>
          <div class="mt-6 flex justify-center gap-4">
            <a href="/request" class="bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 font-semibold text-xs px-4 py-2 rounded-lg shadow-sm transition-all">
              Submit Another Request
            </a>
            <a href="/" class="bg-brand-600 hover:bg-brand-700 text-white font-semibold text-xs px-4 py-2 rounded-lg shadow-sm transition-all">
              Go to Home Page
            </a>
          </div>
        </div>
      <% } else { %>
        <!-- Submission Form -->
        <form action="/request" method="POST" class="space-y-6">
          
          <div>
            <label for="app_name" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Software / App Name <span class="text-red-500">*</span></label>
            <div class="relative rounded-lg shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                <i data-lucide="package" class="w-5 h-5"></i>
              </div>
              <input 
                type="text" 
                name="app_name" 
                id="app_name" 
                required 
                placeholder="e.g. VS Code, Google Chrome, WinRAR"
                class="w-full pl-10 pr-4 py-3 border border-slate-200 rounded-lg bg-slate-50 focus:bg-white text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 focus:outline-none transition-all"
              >
            </div>
            <p class="text-slate-400 text-[10px] mt-1.5">Enter the exact name of the application you need.</p>
          </div>

          <div>
            <label for="email" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Your Email Address <span class="text-slate-400 font-normal">(Optional)</span></label>
            <div class="relative rounded-lg shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                <i data-lucide="mail" class="w-5 h-5"></i>
              </div>
              <input 
                type="email" 
                name="email" 
                id="email" 
                placeholder="e.g. you@example.com"
                class="w-full pl-10 pr-4 py-3 border border-slate-200 rounded-lg bg-slate-50 focus:bg-white text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 focus:outline-none transition-all"
              >
            </div>
            <p class="text-slate-400 text-[10px] mt-1.5">Provide an email if you wish to receive updates when this app is uploaded.</p>
          </div>

          <div>
            <label for="details" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Additional Details <span class="text-slate-400 font-normal">(Optional)</span></label>
            <textarea 
              name="details" 
              id="details" 
              rows="4" 
              placeholder="e.g. Requesting version 3.0 or 64-bit installer. This is a secure utility for..."
              class="w-full px-4 py-3 border border-slate-200 rounded-lg bg-slate-50 focus:bg-white text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 focus:outline-none transition-all"
            ></textarea>
            <p class="text-slate-400 text-[10px] mt-1.5">Specify if you need a specific version, feature set, or architecture (32-bit / 64-bit).</p>
          </div>

          <!-- Submit Button -->
          <div class="pt-4 border-t border-slate-100 flex items-center justify-between gap-4">
            <a href="/" class="text-xs font-semibold text-slate-500 hover:text-slate-700 transition-colors flex items-center gap-1">
              <i data-lucide="arrow-left" class="w-4 h-4"></i>
              <span>Back to Home</span>
            </a>
            
            <button 
              type="submit" 
              class="bg-brand-600 hover:bg-brand-700 text-white font-bold text-xs px-6 py-3 rounded-lg shadow-md hover:shadow-lg transition-all flex items-center gap-1.5 focus:outline-none"
            >
              <i data-lucide="send" class="w-4 h-4"></i>
              <span>Submit App Request</span>
            </button>
          </div>

        </form>
      <% } %>
    </div>
  </div>

  <!-- Trust guidelines -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="flex gap-3 bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <div class="bg-blue-50 text-brand-600 p-2 rounded-lg h-9 w-9 shrink-0 flex items-center justify-center">
        <i data-lucide="shield-alert" class="w-5 h-5"></i>
      </div>
      <div>
        <h4 class="text-xs font-bold text-slate-800">Clean & Safe Verification</h4>
        <p class="text-[10px] text-slate-400 mt-1 leading-normal">
          Every requested application undergoes thorough checking, anti-malware analysis, and sandbox execution before being made available for download.
        </p>
      </div>
    </div>
    <div class="flex gap-3 bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
      <div class="bg-emerald-50 text-emerald-600 p-2 rounded-lg h-9 w-9 shrink-0 flex items-center justify-center">
        <i data-lucide="clock" class="w-5 h-5"></i>
      </div>
      <div>
        <h4 class="text-xs font-bold text-slate-800">Fast Upload Service</h4>
        <p class="text-[10px] text-slate-400 mt-1 leading-normal">
          Popular requests are prioritized and typically uploaded to our high-speed local storage within 24 to 48 hours of validation.
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
