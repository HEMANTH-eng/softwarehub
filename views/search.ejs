<%- include('partials/header') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow space-y-8">

  <!-- Breadcrumbs -->
  <nav class="flex" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3 text-xs font-semibold text-slate-500">
      <li class="inline-flex items-center">
        <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400 flex items-center gap-1.5 transition-colors">
          <i data-lucide="home" class="w-3.5 h-3.5"></i>
          <span>Home</span>
        </a>
      </li>
      <li>
        <div class="flex items-center">
          <i data-lucide="chevron-right" class="w-3 h-3 text-slate-300 dark:text-slate-700"></i>
          <span class="ml-1 md:ml-2 text-slate-700 dark:text-slate-200 font-bold">
            <% if (searchQuery) { %>
              Search: "<%= searchQuery %>"
            <% } else if (activeCategory) { %>
              <%= activeCategory.name %>
            <% } else { %>
              Explore All
            <% } %>
          </span>
        </div>
      </li>
    </ol>
  </nav>
  
  <!-- Header Title bar -->
  <div class="border-b border-slate-200 dark:border-slate-800 pb-5 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight">
        <% if (searchQuery) { %>
          Search Results for "<span class="text-brand-600 dark:text-brand-400"><%= searchQuery %></span>"
        <% } else if (activeCategory) { %>
          Explore Category: <span class="text-brand-600 dark:text-brand-400"><%= activeCategory.name %></span>
        <% } else { %>
          Explore Software Repository
        <% } %>
      </h1>
      
      <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">
        <% if (totalCount > 0) { %>
          Found <%= totalCount %> verified software program(s). Showing page <%= currentPage %> of <%= totalPages %>.
        <% } else { %>
          No verified software matching your query.
        <% } %>
      </p>
    </div>

    <div class="flex items-center gap-3 flex-wrap">
      <!-- Active Category Filter -->
      <% if (activeCategory) { %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-brand-50 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300">
          <i data-lucide="tag" class="w-3.5 h-3.5"></i>
          <span><%= activeCategory.name %></span>
          <a href="/search<%= searchQuery ? '?q=' + searchQuery : '' %>" class="text-brand-400 dark:text-brand-600 hover:text-brand-700 dark:hover:text-brand-400 ml-1">
            <i data-lucide="x" class="w-3 h-3"></i>
          </a>
        </span>
      <% } %>

      <!-- Sort Dropdown -->
      <div class="relative">
        <select 
          id="sort-select"
          onchange="applySortFilter(this.value)"
          class="appearance-none bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg text-xs font-semibold text-slate-600 dark:text-slate-300 pl-3 pr-8 py-2 focus:outline-none focus:border-brand-500 cursor-pointer"
        >
          <option value="name" <%= sortBy === 'name' ? 'selected' : '' %>>Sort: A-Z</option>
          <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Sort: Newest</option>
          <option value="downloads" <%= sortBy === 'downloads' ? 'selected' : '' %>>Sort: Most Downloaded</option>
          <option value="views" <%= sortBy === 'views' ? 'selected' : '' %>>Sort: Most Viewed</option>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none text-slate-400 dark:text-slate-600">
          <i data-lucide="chevrons-up-down" class="w-3.5 h-3.5"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- Search Results Listing Grid -->
  <% if (results && results.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% results.forEach(function(item, idx) { %>
        <%- include('partials/software_card', { item: item }) %>
        
        <!-- Blended Native Ad Insertion -->
        <% if (idx === 2 && config.ads.enabled && config.ads.nativeBanner.enabled) { %>
          <%- include('partials/ad_slot', { format: 'nativeBanner' }) %>
        <% } %>
      <% }); %>
    </div>

    <!-- Pagination controls -->
    <% if (totalPages > 1) { %>
      <div class="flex items-center justify-center space-x-2 mt-10 border-t border-slate-100 dark:border-slate-800 pt-6">
        <% if (currentPage > 1) { %>
          <a href="/search?<%= searchQuery ? 'q=' + searchQuery + '&' : '' %><%= activeCategory ? 'category=' + activeCategory.slug + '&' : '' %>sort=<%= sortBy %>&page=<%= currentPage - 1 %>"
            class="px-4 py-2 border border-slate-200 dark:border-slate-800 text-sm font-semibold rounded-lg bg-white dark:bg-slate-900 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-300 flex items-center gap-1">
            <i data-lucide="chevron-left" class="w-4 h-4"></i>
            <span>Prev</span>
          </a>
        <% } %>

        <% for(let i = 1; i <= totalPages; i++) { %>
          <a href="/search?<%= searchQuery ? 'q=' + searchQuery + '&' : '' %><%= activeCategory ? 'category=' + activeCategory.slug + '&' : '' %>sort=<%= sortBy %>&page=<%= i %>"
            class="px-3.5 py-2 border text-sm font-semibold rounded-lg transition-colors <%= currentPage === i ? 'bg-brand-600 border-brand-600 text-white' : 'bg-white dark:bg-slate-900 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800' %>">
            <%= i %>
          </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="/search?<%= searchQuery ? 'q=' + searchQuery + '&' : '' %><%= activeCategory ? 'category=' + activeCategory.slug + '&' : '' %>sort=<%= sortBy %>&page=<%= currentPage + 1 %>"
            class="px-4 py-2 border border-slate-200 dark:border-slate-800 text-sm font-semibold rounded-lg bg-white dark:bg-slate-900 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-300 flex items-center gap-1">
            <span>Next</span>
            <i data-lucide="chevron-right" class="w-4 h-4"></i>
          </a>
        <% } %>
      </div>
    <% } %>
  <% } else { %>
    <!-- Empty Search State -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-12 text-center max-w-lg mx-auto shadow-sm my-8">
      <div class="w-12 h-12 bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-550 rounded-full flex items-center justify-center mx-auto mb-4">
        <i data-lucide="search" class="w-6 h-6"></i>
      </div>
      <h3 class="font-bold text-slate-800 dark:text-slate-200 text-base">No matches found</h3>
      <p class="text-slate-400 dark:text-slate-500 text-xs mt-1.5 leading-relaxed">
        We couldn't find any software matching "<%= searchQuery %>". Check your spelling, try adjusting your filters, or browse all categories above.
      </p>
      
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <a 
          href="/" 
          class="bg-brand-600 hover:bg-brand-700 text-white text-xs font-semibold px-4 py-2 rounded-lg shadow-sm transition-colors"
        >
          Return Home
        </a>
        <a 
          href="/search" 
          class="bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-350 text-xs font-semibold px-4 py-2 rounded-lg transition-colors"
        >
          View All Software
        </a>
      </div>
    </div>

    <!-- Popular Fallback Suggestions -->
    <% if (typeof popularFallback !== 'undefined' && popularFallback.length > 0) { %>
      <div class="mt-8">
        <div class="flex items-center gap-2 mb-6">
          <div class="bg-amber-500 text-white p-1 rounded-md">
            <i data-lucide="trending-up" class="w-4 h-4"></i>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white">Popular Software You Might Like</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% popularFallback.forEach(function(item) { %>
            <%- include('partials/software_card', { item: item }) %>
          <% }); %>
        </div>
      </div>
    <% } %>
  <% } %>

</div>

<script>
function applySortFilter(sortValue) {
  const url = new URL(window.location.href);
  url.searchParams.set('sort', sortValue);
  url.searchParams.set('page', '1'); // Reset to page 1 on sort change
  window.location.href = url.toString();
}
</script>

<%- include('partials/footer') %>
