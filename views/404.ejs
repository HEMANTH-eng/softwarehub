<%- include('partials/header') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center flex-grow flex flex-col items-center justify-center">
  <div class="bg-white border border-slate-200 rounded-2xl p-12 max-w-lg shadow-sm">
    <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
      <i data-lucide="alert-triangle" class="w-8 h-8"></i>
    </div>
    
    <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-2">404</h1>
    <h2 class="text-xl font-bold text-slate-800 mb-4">Page Not Found</h2>
    <p class="text-slate-500 text-sm mb-8 leading-relaxed">
      The page you are looking for does not exist or has been moved. Use the search bar above or return to the home page to find your software.
    </p>
    
    <a 
      href="/" 
      class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg shadow-sm transition-colors focus:outline-none"
    >
      <i data-lucide="home" class="w-4 h-4"></i>
      <span>Back to Home</span>
    </a>
  </div>
</div>

<%- include('partials/footer') %>
