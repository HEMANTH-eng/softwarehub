<% 
  // Determine if ads are enabled globally and for this specific format
  const isGlobalEnabled = typeof config !== 'undefined' && config.ads && config.ads.enabled;
  const formatConfig = isGlobalEnabled && config.ads[format] ? config.ads[format] : null;
  const isFormatEnabled = formatConfig && formatConfig.enabled;
  const zoneId = formatConfig ? formatConfig.zoneId : '';

  // Helper to extract script src or construct it dynamically
  function getAdScriptSrc(val, template) {
    if (!val) return '';
    // If it's a full script tag, extract the src attribute
    if (val.includes('src=')) {
      const m = val.match(/src=["']([^"']+)["']/);
      if (m) return m[1];
    }
    // If it's a URL
    if (val.startsWith('http://') || val.startsWith('https://') || val.startsWith('//')) {
      return val;
    }
    // If it's a zone ID, use the default template
    return template.replace('{zoneId}', val);
  }
%>

<% if (isFormatEnabled) { %>
  <% if (zoneId && zoneId.trim() !== '') { %>
    <!-- Real Adsterra Script Block -->
    <div class="ad-container my-4 flex justify-center text-center">
      <% if (format === 'banner') { %>
        <div class="w-full max-w-[728px] overflow-hidden">
          <% 
             let cleanZone = zoneId;
             if (zoneId.includes('src=')) {
               const m = zoneId.match(/\/([a-f0-9]{32})/);
               if (m) cleanZone = m[1];
             } else if (zoneId.startsWith('http') || zoneId.startsWith('//')) {
               const m = zoneId.match(/\/([a-f0-9]{32})/);
               if (m) cleanZone = m[1];
             }
          %>
          <script type="text/javascript">
            atOptions = {
              'key' : '<%= cleanZone %>',
              'format' : 'iframe',
              'height' : 90,
              'width' : 728,
              'params' : {}
            };
          </script>
          <script type="text/javascript" src="//www.highperformanceformat.com/<%= cleanZone %>/invoke.js"></script>
        </div>
      <% } else if (format === 'nativeBanner') { %>
        <div class="w-full overflow-hidden">
          <%
             const nativeSrc = getAdScriptSrc(zoneId, 'https://pl30433994.effectivecpmnetwork.com/{zoneId}/invoke.js');
             let cleanZone = zoneId;
             // Extract 32-character hex zone ID
             const m = nativeSrc.match(/\/([a-f0-9]{32})/);
             if (m) cleanZone = m[1];
          %>
          <script async="async" data-cfasync="false" src="<%= nativeSrc %>"></script>
          <div id="container-<%= cleanZone %>"></div>
        </div>
      <% } else if (format === 'socialBar') { %>
        <div id="social-bar-slot" class="fixed bottom-0 left-0 right-0 z-50 p-4 bg-white border-t border-slate-200 shadow-2xl flex items-center justify-between max-w-lg mx-auto sm:rounded-t-xl">
          <div class="flex-1">
            <%
               let socialBarSrc = zoneId;
               if (zoneId.includes('src=')) {
                 const m = zoneId.match(/src=["']([^"']+)["']/);
                 if (m) socialBarSrc = m[1];
               } else if (!zoneId.startsWith('http') && !zoneId.startsWith('//')) {
                 if (zoneId.length === 32) {
                   const s1 = zoneId.substring(0, 2);
                   const s2 = zoneId.substring(2, 4);
                   const s3 = zoneId.substring(4, 6);
                   socialBarSrc = `https://pl30433995.effectivecpmnetwork.com/${s1}/${s2}/${s3}/${zoneId}.js`;
                 } else {
                   socialBarSrc = `//pl20000000.highperformanceformat.com/a4/b3/c2/${zoneId}/invoke.js`;
                 }
               }
            %>
            <script type='text/javascript' src='<%= socialBarSrc %>'></script>
          </div>
          <button id="dismiss-social-bar" class="ml-4 p-1 rounded-full hover:bg-slate-100 text-slate-400 hover:text-slate-600 focus:outline-none">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <!-- Mock ad placeholder (for development and demonstration) -->
    <% if (format === 'nativeBanner') { %>
      <div class="ad-slot-placeholder border-2 border-dashed border-slate-200 rounded-xl overflow-hidden flex flex-col justify-between h-full p-5 min-h-[220px]">
        <div class="flex flex-col items-start gap-4">
          <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold bg-slate-200 text-slate-500 uppercase tracking-wider">
            Advertisement
          </span>
          <div class="flex items-center gap-4 w-full">
            <div class="w-12 h-12 bg-slate-200 rounded-xl flex items-center justify-center text-slate-400">
              <i data-lucide="megaphone" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="h-4 bg-slate-200 w-32 rounded"></div>
              <div class="h-3 bg-slate-200 w-20 rounded mt-2"></div>
            </div>
          </div>
          <div class="w-full space-y-2">
            <div class="h-3 bg-slate-200 w-full rounded"></div>
            <div class="h-3 bg-slate-200 w-5/6 rounded"></div>
          </div>
        </div>
        <div class="h-8 bg-slate-200 w-full rounded mt-4 flex items-center justify-center text-xs font-semibold text-slate-400 uppercase tracking-wider">
          Sponsored Link
        </div>
      </div>
    <% } else if (format === 'banner') { %>
      <div class="ad-slot-placeholder border-2 border-dashed border-slate-200 rounded-lg p-4 my-6 flex flex-col items-center justify-center min-h-[90px] w-full max-w-[728px] mx-auto">
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Advertisement</span>
        <div class="text-xs text-slate-400 font-semibold flex items-center gap-1">
          <i data-lucide="image" class="w-3.5 h-3.5"></i>
          <span>728x90 Leaderboard Banner Slot</span>
        </div>
      </div>
    <% } else if (format === 'socialBar') { %>
      <div id="social-bar-slot" data-auto-hide="true" class="fixed bottom-0 left-0 right-0 z-50 p-4 bg-white border-t border-slate-200 shadow-2xl flex items-center justify-between max-w-lg mx-auto rounded-t-2xl border-x border-slate-100">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center">
            <i data-lucide="sparkles" class="w-5 h-5"></i>
          </div>
          <div>
            <h4 class="text-xs font-bold text-slate-800">Recommended for your PC</h4>
            <p class="text-[10px] text-slate-400">Boost download speeds up to 5x. Click here to scan.</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <a href="#" class="bg-brand-600 hover:bg-brand-700 text-white font-bold text-xs px-3 py-1.5 rounded-lg transition-colors shadow">
            Clean Now
          </a>
          <button id="dismiss-social-bar" class="p-1 rounded-full hover:bg-slate-100 text-slate-400 hover:text-slate-600 focus:outline-none">
            <i data-lucide="x" class="w-4 h-4"></i>
          </button>
        </div>
      </div>
    <% } %>
  <% } %>
<% } %>
