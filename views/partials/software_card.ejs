<% 
  // Generate safe URL slug on-the-fly for software detail links
  const swSlug = item.name
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');

  // Download count badge helper
  function getDownloadBadge(count) {
    if (count >= 10000) return '10K+';
    if (count >= 5000) return '5K+';
    if (count >= 1000) return '1K+';
    if (count >= 500) return '500+';
    if (count >= 100) return '100+';
    return null;
  }
  const badge = getDownloadBadge(item.download_count);
%>
<div class="software-card bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden flex flex-col justify-between h-full hover:shadow-lg transition-all duration-200">
  <div class="p-5 flex flex-col items-start gap-4">
    <!-- Badges Row -->
    <div class="flex flex-wrap gap-1.5">
      <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold bg-brand-50 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300 tracking-wide uppercase">
        <%= item.category_name %>
      </span>
      <% if (badge) { %>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-200 dark:bg-amber-950/40 dark:text-amber-300 dark:border-amber-900/50">
          <i data-lucide="flame" class="w-3 h-3"></i>
          <span><%= badge %> Downloads</span>
        </span>
      <% } %>
    </div>

    <div class="flex items-center gap-4 w-full">
      <!-- Thumbnail Icon -->
      <div class="w-14 h-14 shrink-0 rounded-xl overflow-hidden border border-slate-100 dark:border-slate-800 flex items-center justify-center bg-slate-50 dark:bg-slate-850">
        <% if (item.icon_image) { %>
          <!-- Use the uploaded image file -->
          <img src="/storage/images/<%= item.icon_image %>" alt="<%= item.name %> icon" class="w-full h-full object-cover" loading="lazy">
        <% } else { %>
          <!-- Fallback icon -->
          <div class="w-full h-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center text-slate-400 dark:text-slate-500">
            <i data-lucide="package" class="w-8 h-8"></i>
          </div>
        <% } %>
      </div>
      
      <!-- Title & Size -->
      <div class="min-w-0">
        <h3 class="font-bold text-slate-900 dark:text-white text-base truncate hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
          <a href="/software/<%= item.id %>/<%= swSlug %>"><%= item.name %></a>
        </h3>
        <div class="flex items-center gap-1 text-xs text-slate-400 dark:text-slate-500 mt-0.5">
          <i data-lucide="database" class="w-3 h-3"></i>
          <span><%= item.size %></span>
          <% if (item.version) { %>
            <span class="px-1 text-slate-300 dark:text-slate-700">&bull;</span>
            <span>v<%= item.version %></span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Short Description -->
    <p class="text-slate-500 dark:text-slate-400 text-xs leading-relaxed line-clamp-3">
      <%= item.short_description %>
    </p>
  </div>

  <!-- Card Action Footer -->
  <div class="px-5 py-4 bg-slate-50 dark:bg-slate-900/60 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
    <div class="flex items-center gap-3 text-[11px] font-semibold text-slate-400 dark:text-slate-500">
      <span class="flex items-center gap-1">
        <i data-lucide="eye" class="w-3.5 h-3.5"></i>
        <span><%= item.view_count %></span>
      </span>
      <span class="flex items-center gap-1">
        <i data-lucide="download" class="w-3.5 h-3.5"></i>
        <span><%= item.download_count %></span>
      </span>
    </div>
    
    <a 
      href="/software/<%= item.id %>/<%= swSlug %>" 
      class="text-xs font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 flex items-center gap-1 focus:outline-none"
    >
      <span>Details</span>
      <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
    </a>
  </div>
</div>
