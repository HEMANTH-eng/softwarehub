<% 
  // Generate safe URL slug on-the-fly for software detail links
  const swSlug = item.name
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
%>
<div class="software-card bg-white border border-slate-200 rounded-xl overflow-hidden flex flex-col justify-between h-full hover:shadow-lg transition-all duration-200">
  <div class="p-5 flex flex-col items-start gap-4">
    <!-- Category Badge -->
    <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold bg-brand-50 text-brand-700 tracking-wide uppercase">
      <%= item.category_name %>
    </span>

    <div class="flex items-center gap-4 w-full">
      <!-- Thumbnail Icon -->
      <div class="w-14 h-14 shrink-0 rounded-xl overflow-hidden border border-slate-100 flex items-center justify-center bg-slate-50">
        <% if (item.icon_image) { %>
          <!-- Use the uploaded image file -->
          <img src="/storage/images/<%= item.icon_image %>" alt="<%= item.name %> icon" class="w-full h-full object-cover">
        <% } else { %>
          <!-- Fallback icon -->
          <div class="w-full h-full bg-slate-200 flex items-center justify-center text-slate-400">
            <i data-lucide="package" class="w-8 h-8"></i>
          </div>
        <% } %>
      </div>
      
      <!-- Title & Size -->
      <div class="min-w-0">
        <h3 class="font-bold text-slate-900 text-base truncate hover:text-brand-600 transition-colors">
          <a href="/software/<%= item.id %>/<%= swSlug %>"><%= item.name %></a>
        </h3>
        <div class="flex items-center gap-1 text-xs text-slate-400 mt-0.5">
          <i data-lucide="database" class="w-3 h-3"></i>
          <span><%= item.size %></span>
          <% if (item.version) { %>
            <span class="px-1 text-slate-300">•</span>
            <span>v<%= item.version %></span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Short Description -->
    <p class="text-slate-500 text-xs leading-relaxed line-clamp-3">
      <%= item.short_description %>
    </p>
  </div>

  <!-- Card Action Footer -->
  <div class="px-5 py-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between">
    <div class="flex items-center gap-3 text-[11px] font-semibold text-slate-400">
      <span class="flex items-center gap-1">
        <i data-lucide="eye" class="w-3.5 h-3.5"></i>
        <span><%= item.view_count %></span>
      </span>
      <span class="flex items-center gap-1">
        <i data-lucide="download" class="w-3.5 h-3.5"></i>
        <span><%= item.download_count %></span>
      </span>
    </div>
    
    <a 
      href="/software/<%= item.id %>/<%= swSlug %>" 
      class="text-xs font-semibold text-brand-600 hover:text-brand-700 flex items-center gap-1 focus:outline-none"
    >
      <span>Details</span>
      <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
    </a>
  </div>
</div>
