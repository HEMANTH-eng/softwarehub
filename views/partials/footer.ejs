  </main>

  <!-- Back to Top Button -->
  <button 
    id="back-to-top" 
    class="fixed bottom-6 right-6 z-50 hidden bg-brand-600 hover:bg-brand-700 text-white p-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 focus:outline-none"
    aria-label="Back to top"
  >
    <i data-lucide="chevron-up" class="w-5 h-5"></i>
  </button>

  <!-- Footer Navigation -->
  <footer class="bg-white border-t border-slate-200 py-8 mt-12 shrink-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        
        <div class="flex items-center space-x-2">
          <img src="/images/logo.png" alt="Logo" class="w-8 h-8 object-contain">
          <span class="font-bold text-slate-800 text-sm">
            <%= typeof config !== 'undefined' && config.site ? config.site.name : 'Software Hub' %>
          </span>
        </div>

        <p class="text-xs text-slate-400">
          &copy; <%= new Date().getFullYear() %> <%= typeof config !== 'undefined' && config.site ? config.site.name : 'Software Hub' %>. All rights reserved. Free Windows software repository.
        </p>

        <div class="flex items-center space-x-4 text-xs text-slate-400">
          <a href="/about" class="hover:text-slate-600 transition-colors">About</a>
          <a href="/feed.xml" class="hover:text-slate-600 transition-colors flex items-center gap-1">
            <i data-lucide="rss" class="w-3 h-3"></i>
            <span>RSS</span>
          </a>
          <a href="/admin/login" class="hover:text-slate-600 transition-colors">Admin Login</a>
        </div>

      </div>
    </div>
  </footer>

  <!-- Main JavaScript File -->
  <script src="/js/main.js"></script>
</body>
</html>
