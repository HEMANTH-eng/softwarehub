  </main>

  <!-- Back to Top Button -->
  <button 
    id="back-to-top" 
    class="fixed bottom-6 right-6 z-50 hidden bg-brand-600 hover:bg-brand-700 text-white p-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 focus:outline-none"
    aria-label="Back to top"
  >
    <i data-lucide="chevron-up" class="w-5 h-5"></i>
  </button>

  <!-- Footer Navigation -->
  <footer class="bg-white border-t border-slate-200 dark:bg-slate-900 dark:border-slate-800 py-8 mt-12 shrink-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        
        <div class="flex items-center space-x-2">
          <img src="/images/logo.png" alt="Logo" class="w-8 h-8 object-contain">
          <span class="font-bold text-slate-800 dark:text-slate-200 text-sm">
            <%= typeof config !== 'undefined' && config.site ? config.site.name : 'Software Hub' %>
          </span>
        </div>

        <p class="text-xs text-slate-400 dark:text-slate-500">
          &copy; <%= new Date().getFullYear() %> <%= typeof config !== 'undefined' && config.site ? config.site.name : 'Software Hub' %>. All rights reserved. Free <%= (typeof platform !== 'undefined' && platform === 'android') ? 'Android' : 'Windows' %> software repository.
        </p>

        <div class="flex items-center space-x-4 text-xs text-slate-400 dark:text-slate-500">
          <a href="/about" class="hover:text-slate-600 dark:hover:text-slate-300 transition-colors">About</a>
          <a href="/feed.xml" class="hover:text-slate-600 dark:hover:text-slate-300 transition-colors flex items-center gap-1">
            <i data-lucide="rss" class="w-3 h-3"></i>
            <span>RSS</span>
          </a>
          <a href="/admin/login" class="hover:text-slate-600 dark:hover:text-slate-300 transition-colors">Admin Login</a>
        </div>

      </div>
    </div>
  </footer>

  <!-- Main JavaScript File -->
  <script src="/js/main.js"></script>

  <% if (typeof config !== 'undefined' && config.ads && config.ads.enabled && config.ads.popunder && config.ads.popunder.enabled && config.ads.popunder.zoneId) { %>
    <%
       let popunderSrc = config.ads.popunder.zoneId;
       if (popunderSrc.includes('src=')) {
         const m = popunderSrc.match(/src=["']([^"']+)["']/);
         if (m) popunderSrc = m[1];
       } else if (!popunderSrc.startsWith('http') && !popunderSrc.startsWith('//')) {
         if (popunderSrc.length === 32) {
           const p1 = popunderSrc.substring(0, 2);
           const p2 = popunderSrc.substring(2, 4);
           const p3 = popunderSrc.substring(4, 6);
           popunderSrc = `https://pl30433993.effectivecpmnetwork.com/${p1}/${p2}/${p3}/${popunderSrc}.js`;
         } else {
           popunderSrc = `//www.highperformanceformat.com/${popunderSrc}/invoke.js`;
         }
       }
    %>
    <script type="text/javascript" src="<%= popunderSrc %>"></script>
  <% } %>
</body>
</html>
