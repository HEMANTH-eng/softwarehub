<%- include('partials/header') %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">

  <!-- Page Header -->
  <div class="text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-50 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300 text-xs font-semibold mb-4">
      <i data-lucide="info" class="w-3.5 h-3.5"></i>
      <span>About Us</span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">
      About <%= config.site.name %>
    </h1>
    <p class="mt-3 text-slate-500 dark:text-slate-400 text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
      A free, verified Windows software download platform. No accounts, no malware, just clean software delivered directly to you.
    </p>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-5 text-center shadow-sm">
      <div class="text-2xl font-extrabold text-brand-600"><%= totalSoftware %></div>
      <div class="text-xs text-slate-400 dark:text-slate-500 mt-1 uppercase font-semibold">Software Titles</div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-5 text-center shadow-sm">
      <div class="text-2xl font-extrabold text-emerald-600"><%= totalDownloads %></div>
      <div class="text-xs text-slate-400 dark:text-slate-500 mt-1 uppercase font-semibold">Total Downloads</div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-5 text-center shadow-sm">
      <div class="text-2xl font-extrabold text-amber-600">100%</div>
      <div class="text-xs text-slate-400 dark:text-slate-500 mt-1 uppercase font-semibold">Virus-Free</div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-5 text-center shadow-sm">
      <div class="text-2xl font-extrabold text-violet-600">0</div>
      <div class="text-xs text-slate-400 dark:text-slate-500 mt-1 uppercase font-semibold">Accounts Needed</div>
    </div>
  </div>

  <!-- Mission Section -->
  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 shadow-sm space-y-6">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
      <i data-lucide="target" class="w-5 h-5 text-brand-600"></i>
      Our Mission
    </h2>
    <div class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed space-y-4">
      <p>
        <strong><%= config.site.name %></strong> was built with one goal: provide a fast, clean, and trustworthy place to download Windows software. 
        No sign-ups, no bloatware bundles, no deceptive download buttons.
      </p>
      <p>
        Every application in our repository is hand-picked, scanned for malware, and tested before being made available. 
        We believe finding and downloading software should be simple and safe.
      </p>
    </div>
  </div>

  <!-- What We Offer -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
      <div class="bg-brand-50 dark:bg-brand-950/40 text-brand-600 dark:text-brand-400 w-10 h-10 rounded-lg flex items-center justify-center mb-4">
        <i data-lucide="shield-check" class="w-5 h-5"></i>
      </div>
      <h3 class="font-bold text-slate-900 dark:text-white text-sm">Verified & Safe</h3>
      <p class="text-slate-500 dark:text-slate-400 text-xs mt-2 leading-relaxed">
        Every file is scanned with multiple antivirus engines and tested in sandbox environments before upload.
      </p>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
      <div class="bg-emerald-50 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400 w-10 h-10 rounded-lg flex items-center justify-center mb-4">
        <i data-lucide="zap" class="w-5 h-5"></i>
      </div>
      <h3 class="font-bold text-slate-900 dark:text-white text-sm">Direct Downloads</h3>
      <p class="text-slate-500 dark:text-slate-400 text-xs mt-2 leading-relaxed">
        No download managers, no toolbars, no third-party installers. Just the original file served from our fast mirrors.
      </p>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
      <div class="bg-violet-50 dark:bg-violet-950/40 text-violet-600 dark:text-violet-400 w-10 h-10 rounded-lg flex items-center justify-center mb-4">
        <i data-lucide="user-x" class="w-5 h-5"></i>
      </div>
      <h3 class="font-bold text-slate-900 dark:text-white text-sm">No Account Required</h3>
      <p class="text-slate-500 dark:text-slate-400 text-xs mt-2 leading-relaxed">
        Browse, search, and download freely. We don't collect personal data or require registration.
      </p>
    </div>
  </div>

  <!-- DMCA / Legal -->
  <div class="bg-slate-900 dark:bg-slate-900/60 dark:border dark:border-slate-800 text-white rounded-2xl p-8 shadow-sm space-y-4">
    <h2 class="text-lg font-bold flex items-center gap-2">
      <i data-lucide="scale" class="w-5 h-5 text-brand-400"></i>
      DMCA & Takedown Policy
    </h2>
    <div class="text-slate-300 dark:text-slate-400 text-xs leading-relaxed space-y-3">
      <p>
        We respect intellectual property rights. If you believe any software hosted on this site infringes your copyright,
        please contact us with the following information:
      </p>
      <ul class="list-disc list-inside space-y-1 text-slate-400 dark:text-slate-500">
        <li>Identification of the copyrighted work</li>
        <li>The URL of the infringing material on our site</li>
        <li>Your contact information (name, email, phone)</li>
        <li>A statement of good faith belief that the use is not authorized</li>
      </ul>
      <p>
        We will review and respond to valid takedown requests within 48 hours.
      </p>
    </div>
  </div>

  <!-- Contact -->
  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 shadow-sm text-center">
    <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Get In Touch</h2>
    <p class="text-slate-500 dark:text-slate-400 text-xs leading-relaxed max-w-lg mx-auto">
      Have questions, feedback, or a DMCA request? Reach out to us and we'll respond as quickly as possible.
    </p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
      <a href="/request" class="bg-brand-600 hover:bg-brand-700 text-white text-xs font-semibold px-5 py-2.5 rounded-lg shadow-sm transition-colors flex items-center gap-1.5">
        <i data-lucide="message-square-plus" class="w-4 h-4"></i>
        <span>Request Software</span>
      </a>
      <a href="/" class="bg-slate-100 hover:bg-slate-200 text-slate-700 dark:bg-slate-800 dark:hover:bg-slate-700 dark:text-slate-300 text-xs font-semibold px-5 py-2.5 rounded-lg transition-colors flex items-center gap-1.5">
        <i data-lucide="home" class="w-4 h-4"></i>
        <span>Back to Home</span>
      </a>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
